# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Fernet encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=

# Gmail OAuth2 credentials (downloaded from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=data/gmail_credentials.json
GMAIL_TOKEN_PATH=data/gmail_token.json

# Database
DB_PATH=data/jobhunter.db

# Personal email for forwarding important messages
PERSONAL_EMAIL=

# Daily budget cap (USD)
DAILY_BUDGET_USD=15.00

# LinkedIn authentication is handled manually via the browser window.
# On first run (or when the session expires), a browser will open at
# linkedin.com/login and wait for you to sign in with your normal method
# (passkey, 1Password, SSO, etc.). The session is then persisted to
# data/browser_state/ so subsequent runs skip login entirely.
